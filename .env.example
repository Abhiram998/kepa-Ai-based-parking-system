# Database Configuration (Supabase/PostgreSQL)
# Format: postgresql://[user]:[password]@[db-host]:5432/postgres
DATABASE_URL=postgresql://postgres:[password]@db.your-id.supabase.co:5432/postgres

# Security
# Comma-separated list of allowed origins (e.g., https://myapp.railway.app,http://localhost:5173)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Optional: Timezone
TZ=UTC

# AI Services
GEMINI_API_KEY=your_gemini_api_key_here
